# ── MongoDB ──────────────────────────────────────────────────
# Local: mongodb://localhost:27017/conectasus
# Atlas:  mongodb+srv://usuario:senha@cluster.mongodb.net/conectasus
MONGO_URI=mongodb://localhost:27017/conectasus

# ── Servidor ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── JWT ──────────────────────────────────────────────────────
# Gere um segredo forte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=seu_segredo_jwt_aqui
JWT_EXPIRES_IN=7d
